{
    "name": "gafarzade98/lara-invoice",
    "description": "Laravel Invoice Generator — SVG to PDF",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "GafarZade98\\LaraInvoice\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Gafar Zade",
            "email": "qafarzade98@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "barryvdh/laravel-dompdf": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Gafarzade98\\LaraInvoice\\InvoiceServiceProvider"
            ],
            "aliases": {
                "Invoice": "Gafarzade98\\LaraInvoice\\Facades\\Invoice"
            }
        }
    }
}